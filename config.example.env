# Campus account examples:
#   NJUPT campus network: xxx
#   China Mobile / NJUPT-CMCC: xxx@cmcc
#   China Telecom / NJUPT-CHINANET: xxx@njxy
#   China Unicom: not confirmed; check the portal request's user_account value.
CAMPUS_USER_ACCOUNT='xxx@cmcc'

# Campus network password.
CAMPUS_USER_PASSWORD='your_password'

# Login endpoint. This default is for NJUPT eportal.
CAMPUS_LOGIN_URL='https://p.njupt.edu.cn:802/eportal/portal/login'

# Primary lightweight probe. Expected status is 204.
CAMPUS_PROBE_URL='http://cp.cloudflare.com/generate_204'
# Optional: more primary probes with the same expected status, separated by spaces.
# CAMPUS_PROBE_URLS='http://cp.cloudflare.com/generate_204 http://your-own-probe.example.com/generate_204'
CAMPUS_PROBE_EXPECT='204'

# When every primary probe fails, HTTPS requests to these sites confirm whether the
# Internet is actually down. Any 2xx or 3xx response prevents a campus login.
CAMPUS_CONFIRM_URLS='https://www.baidu.com/favicon.ico https://www.qq.com/favicon.ico'

# Run login after N consecutive probe failures.
CAMPUS_FAIL_THRESHOLD='2'

# Avoid repeated login requests when the portal is unavailable.
CAMPUS_COOLDOWN_SECONDS='60'
# Failed login retries back off exponentially, capped at this value.
CAMPUS_MAX_COOLDOWN_SECONDS='900'

# Wait before verifying connectivity after login.
CAMPUS_AFTER_LOGIN_DELAY='10'

# Probe curl timeouts.
CAMPUS_CONNECT_TIMEOUT='2'
CAMPUS_MAX_TIME='5'
