# Campus account, for example: 1224077021@cmcc
CAMPUS_USER_ACCOUNT='your_account@cmcc'

# Campus network password.
CAMPUS_USER_PASSWORD='your_password'

# Login endpoint. This default is for NJUPT eportal.
CAMPUS_LOGIN_URL='https://p.njupt.edu.cn:802/eportal/portal/login'

# Lightweight connectivity probe. Expected status is 204.
CAMPUS_PROBE_URL='http://cp.cloudflare.com/generate_204'
CAMPUS_PROBE_EXPECT='204'

# Run login after N consecutive probe failures.
CAMPUS_FAIL_THRESHOLD='2'

# Avoid repeated login requests when the portal is unavailable.
CAMPUS_COOLDOWN_SECONDS='60'

# Wait before verifying connectivity after login.
CAMPUS_AFTER_LOGIN_DELAY='5'

# Probe curl timeouts.
CAMPUS_CONNECT_TIMEOUT='2'
CAMPUS_MAX_TIME='5'
