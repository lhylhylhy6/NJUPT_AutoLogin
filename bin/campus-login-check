#!/usr/bin/env bash
set -u

ENV_FILE="${CAMPUS_ENV_FILE:-$HOME/.config/campus-login/env}"
STATE_DIR="${CAMPUS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/campus-login}"
STATE_FILE="$STATE_DIR/state"
LOCK_FILE="$STATE_DIR/check.lock"
LOG_FILE="${CAMPUS_LOG_FILE:-$STATE_DIR/check.log}"
PROBE_RESULT_FILE="$STATE_DIR/last_probe_result"
LOGIN_RESULT_FILE="$STATE_DIR/last_login_result"

mkdir -p "$STATE_DIR"
chmod 700 "$STATE_DIR" 2>/dev/null || true

log() {
    local message="$*"
    printf '%s - %s\n' "$(date '+%F %T')" "$message" >> "$LOG_FILE"
    logger -t campus-login-check -- "$message" 2>/dev/null || true
}

if [ -r "$ENV_FILE" ]; then
    # shellcheck source=/dev/null
    . "$ENV_FILE"
else
    log "env file is not readable: $ENV_FILE"
    exit 1
fi

CAMPUS_LOGIN_URL="${CAMPUS_LOGIN_URL:-https://p.njupt.edu.cn:802/eportal/portal/login}"
CAMPUS_CONTEXT_URL="${CAMPUS_CONTEXT_URL:-http://6.6.6.6/?isReback=1}"
CAMPUS_ACCOUNT_PREFIX="${CAMPUS_ACCOUNT_PREFIX:-,0,}"
CAMPUS_WLAN_USER_IP="${CAMPUS_WLAN_USER_IP:-}"
CAMPUS_PROBE_URL="${CAMPUS_PROBE_URL:-http://cp.cloudflare.com/generate_204}"
# CAMPUS_PROBE_URLS remains a compatible way to add more 204-style primary probes.
CAMPUS_PROBE_URLS="${CAMPUS_PROBE_URLS:-$CAMPUS_PROBE_URL}"
CAMPUS_CONFIRM_URLS="${CAMPUS_CONFIRM_URLS:-https://www.baidu.com/favicon.ico https://www.qq.com/favicon.ico}"
CAMPUS_PROBE_EXPECT="${CAMPUS_PROBE_EXPECT:-204}"
CAMPUS_FAIL_THRESHOLD="${CAMPUS_FAIL_THRESHOLD:-2}"
CAMPUS_COOLDOWN_SECONDS="${CAMPUS_COOLDOWN_SECONDS:-60}"
CAMPUS_MAX_COOLDOWN_SECONDS="${CAMPUS_MAX_COOLDOWN_SECONDS:-900}"
CAMPUS_AFTER_LOGIN_DELAY="${CAMPUS_AFTER_LOGIN_DELAY:-10}"
CAMPUS_CONNECT_TIMEOUT="${CAMPUS_CONNECT_TIMEOUT:-2}"
CAMPUS_MAX_TIME="${CAMPUS_MAX_TIME:-5}"

if [ -z "${CAMPUS_USER_ACCOUNT:-}" ] || [ -z "${CAMPUS_USER_PASSWORD:-}" ]; then
    log "missing CAMPUS_USER_ACCOUNT or CAMPUS_USER_PASSWORD"
    exit 1
fi

exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    exit 0
fi

FAIL_COUNT=0
LAST_LOGIN=0
LOGIN_FAILURES=0
LAST_STATUS="unknown"
LAST_CODE="000"
if [ -r "$STATE_FILE" ]; then
    # shellcheck source=/dev/null
    . "$STATE_FILE"
fi

save_state() {
    local tmp="$STATE_FILE.$$"
    umask 077
    {
        printf 'FAIL_COUNT=%s\n' "${FAIL_COUNT:-0}"
        printf 'LAST_LOGIN=%s\n' "${LAST_LOGIN:-0}"
        printf 'LOGIN_FAILURES=%s\n' "${LOGIN_FAILURES:-0}"
        printf 'LAST_STATUS=%q\n' "${LAST_STATUS:-unknown}"
        printf 'LAST_CODE=%q\n' "${LAST_CODE:-000}"
    } > "$tmp"
    mv "$tmp" "$STATE_FILE"
}

write_private_file() {
    local path="$1"
    local content="$2"
    local tmp="$path.$$"
    umask 077
    printf '%s\n' "$content" > "$tmp"
    chmod 600 "$tmp" 2>/dev/null || true
    mv "$tmp" "$path"
}

normalize_text_file() {
    tr '\r\n' ' ' < "$1" | sed -e 's/[[:space:]][[:space:]]*/ /g' -e 's/[[:space:]]$//'
}

is_expected_probe_code() {
    [ "$1" = "$CAMPUS_PROBE_EXPECT" ]
}

is_success_http_code() {
    [[ "$1" =~ ^[0-9]{3}$ ]] && (( 10#$1 >= 200 && 10#$1 < 400 ))
}

REQUEST_CODE="000"
REQUEST_ERROR=""
request_url() {
    local url="$1"
    local err_file
    err_file="$(mktemp "$STATE_DIR/curl-error.XXXXXX")" || {
        REQUEST_CODE="000"
        REQUEST_ERROR="cannot create curl error file"
        return
    }

    REQUEST_CODE="$(curl -sS -o /dev/null -w '%{http_code}' \
        --connect-timeout "$CAMPUS_CONNECT_TIMEOUT" \
        --max-time "$CAMPUS_MAX_TIME" \
        "$url" 2>"$err_file")" || REQUEST_CODE="000"
    REQUEST_CODE="${REQUEST_CODE:-000}"
    REQUEST_ERROR="$(normalize_text_file "$err_file")"
    rm -f "$err_file"
}

append_probe_detail() {
    local label="$1"
    local url="$2"
    local code="$3"
    local error="$4"
    local detail="$label $url -> HTTP $code"
    if [ -n "$error" ]; then
        detail="$detail; curl: $error"
    fi
    if [ -n "${PROBE_DETAILS:-}" ]; then
        PROBE_DETAILS="$PROBE_DETAILS | $detail"
    else
        PROBE_DETAILS="$detail"
    fi
}

PROBE_DETAILS=""
PROBE_PRIMARY_CODE="000"
PROBE_STATUS="failed"
probe_connectivity() {
    local probe_url
    PROBE_DETAILS=""
    PROBE_PRIMARY_CODE="000"
    PROBE_STATUS="failed"

    for probe_url in $CAMPUS_PROBE_URLS; do
        request_url "$probe_url"
        PROBE_PRIMARY_CODE="$REQUEST_CODE"
        append_probe_detail "primary" "$probe_url" "$REQUEST_CODE" "$REQUEST_ERROR"
        if is_expected_probe_code "$REQUEST_CODE"; then
            PROBE_STATUS="primary"
            write_private_file "$PROBE_RESULT_FILE" "$PROBE_DETAILS"
            return 0
        fi
    done

    # HTTPS confirmation avoids a false login when only the HTTP 204 endpoint is flaky.
    for probe_url in $CAMPUS_CONFIRM_URLS; do
        request_url "$probe_url"
        append_probe_detail "confirmation" "$probe_url" "$REQUEST_CODE" "$REQUEST_ERROR"
        if is_success_http_code "$REQUEST_CODE"; then
            PROBE_STATUS="confirmed"
            write_private_file "$PROBE_RESULT_FILE" "$PROBE_DETAILS"
            return 0
        fi
    done

    write_private_file "$PROBE_RESULT_FILE" "$PROBE_DETAILS"
    return 1
}

extract_response_field() {
    local response_file="$1"
    local key="$2"
    normalize_text_file "$response_file" \
        | sed -nE "s/.*[\\\"']${key}[\\\"'][[:space:]]*:[[:space:]]*[\\\"']?([^,}\\\"']+).*/\\1/p" \
        | head -n 1 \
        | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' \
        | cut -c1-160
}

summarize_login_response() {
    local response_file="$1"
    local key value summary=""
    if [ ! -s "$response_file" ]; then
        printf 'empty response body'
        return
    fi

    for key in result code ret_code msg message error; do
        value="$(extract_response_field "$response_file" "$key")"
        [ -n "$value" ] || continue
        if [ -n "$summary" ]; then
            summary="$summary, "
        fi
        summary="$summary$key=$value"
    done

    if [ -n "$summary" ]; then
        printf '%s' "$summary"
    else
        printf 'unrecognized response body (%s bytes)' "$(wc -c < "$response_file" | tr -d ' ')"
    fi
}

extract_context_ipv4() {
    local context_file="$1"
    local key value
    for key in wlanuserip wlan_user_ip ss5; do
        value="$(normalize_text_file "$context_file" \
            | sed -nE "s/.*${key}[^0-9]*(([0-9]{1,3}\\.){3}[0-9]{1,3}).*/\\1/p" \
            | head -n 1)"
        if [[ "$value" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
            printf '%s' "$value"
            return
        fi
    done
}

discover_wlan_user_ip() {
    local context_file err_file effective_url discovered_ip=""
    if [ -n "$CAMPUS_WLAN_USER_IP" ]; then
        printf '%s' "$CAMPUS_WLAN_USER_IP"
        return
    fi
    [ -n "$CAMPUS_CONTEXT_URL" ] || return

    context_file="$(mktemp "$STATE_DIR/login-context.XXXXXX")" || return
    err_file="$(mktemp "$STATE_DIR/context-error.XXXXXX")" || {
        rm -f "$context_file"
        return
    }
    effective_url="$(curl -k -sS -L -o "$context_file" -w '%{url_effective}' \
        --connect-timeout 3 \
        --max-time 10 \
        --max-redirs 5 \
        "$CAMPUS_CONTEXT_URL" 2>"$err_file")" || effective_url=""
    printf '\n%s\n' "$effective_url" >> "$context_file"
    discovered_ip="$(extract_context_ipv4 "$context_file")"
    rm -f "$context_file" "$err_file"
    printf '%s' "$discovered_ip"
}

LOGIN_CODE="000"
LOGIN_SUMMARY="not attempted"
login_once() {
    local account_file password_file response_file err_file login_account wlan_user_ip request_version
    account_file="$(mktemp "$STATE_DIR/account.XXXXXX")" || return 1
    password_file="$(mktemp "$STATE_DIR/password.XXXXXX")" || {
        rm -f "$account_file"
        return 1
    }
    response_file="$(mktemp "$STATE_DIR/login-response.XXXXXX")" || {
        rm -f "$account_file" "$password_file"
        return 1
    }
    err_file="$(mktemp "$STATE_DIR/login-error.XXXXXX")" || {
        rm -f "$account_file" "$password_file" "$response_file"
        return 1
    }
    chmod 600 "$account_file" "$password_file" "$response_file" 2>/dev/null || true
    login_account="$CAMPUS_USER_ACCOUNT"
    if [ -n "$CAMPUS_ACCOUNT_PREFIX" ]; then
        case "$login_account" in
            "$CAMPUS_ACCOUNT_PREFIX"*) ;;
            *) login_account="$CAMPUS_ACCOUNT_PREFIX$login_account" ;;
        esac
    fi
    printf '%s' "$login_account" > "$account_file"
    printf '%s' "$CAMPUS_USER_PASSWORD" > "$password_file"

    wlan_user_ip="$(discover_wlan_user_ip)"
    request_version="$(date +%s)"

    LOGIN_CODE="$(curl -sS -o "$response_file" -w '%{http_code}' -G \
        --connect-timeout 5 \
        --max-time 20 \
        --user-agent 'Mozilla/5.0 (X11; Linux) AppleWebKit/537.36 Chrome/126 Safari/537.36' \
        --data-urlencode 'callback=dr1003' \
        --data-urlencode 'login_method=1' \
        --data-urlencode "user_account@$account_file" \
        --data-urlencode "user_password@$password_file" \
        --data-urlencode "wlan_user_ip=$wlan_user_ip" \
        --data-urlencode 'wlan_user_ipv6=' \
        --data-urlencode 'wlan_user_mac=000000000000' \
        --data-urlencode 'wlan_ac_ip=' \
        --data-urlencode 'wlan_ac_name=' \
        --data-urlencode 'jsVersion=4.1.3' \
        --data-urlencode 'terminal_type=1' \
        --data-urlencode 'lang=zh-cn' \
        --data-urlencode "v=$request_version" \
        "$CAMPUS_LOGIN_URL" 2>"$err_file")" || LOGIN_CODE="000"
    LOGIN_CODE="${LOGIN_CODE:-000}"
    LOGIN_SUMMARY="$(summarize_login_response "$response_file")"
    if [ -s "$err_file" ]; then
        LOGIN_SUMMARY="$LOGIN_SUMMARY; curl: $(normalize_text_file "$err_file")"
    fi
    if [ -n "$wlan_user_ip" ]; then
        LOGIN_SUMMARY="$LOGIN_SUMMARY; context IP discovered"
    else
        LOGIN_SUMMARY="$LOGIN_SUMMARY; context IP inferred by portal"
    fi
    write_private_file "$LOGIN_RESULT_FILE" "portal HTTP $LOGIN_CODE; $LOGIN_SUMMARY"
    rm -f "$account_file" "$password_file" "$response_file" "$err_file"
}

retry_delay() {
    local delay="$CAMPUS_COOLDOWN_SECONDS"
    local failures="${LOGIN_FAILURES:-0}"
    while [ "$failures" -gt 1 ] && [ "$delay" -lt "$CAMPUS_MAX_COOLDOWN_SECONDS" ]; do
        delay=$(( delay * 2 ))
        failures=$(( failures - 1 ))
    done
    if [ "$delay" -gt "$CAMPUS_MAX_COOLDOWN_SECONDS" ]; then
        delay="$CAMPUS_MAX_COOLDOWN_SECONDS"
    fi
    printf '%s' "$delay"
}

if probe_connectivity; then
    if [ "$PROBE_STATUS" = "primary" ]; then
        if [ "${LAST_STATUS:-unknown}" != "ok" ] || [ "${FAIL_COUNT:-0}" -gt 0 ]; then
            log "connectivity OK via primary probe (HTTP $PROBE_PRIMARY_CODE)"
        fi
        LAST_STATUS="ok"
    else
        if [ "${LAST_STATUS:-unknown}" != "confirmed" ]; then
            log "primary probe unavailable, but HTTPS confirmation succeeded; no login needed: $PROBE_DETAILS"
        fi
        LAST_STATUS="confirmed"
    fi
    FAIL_COUNT=0
    LOGIN_FAILURES=0
    LAST_CODE="$PROBE_PRIMARY_CODE"
    save_state
    exit 0
fi

FAIL_COUNT=$(( ${FAIL_COUNT:-0} + 1 ))
LAST_STATUS="fail"
LAST_CODE="$PROBE_PRIMARY_CODE"

if [ "$FAIL_COUNT" -lt "$CAMPUS_FAIL_THRESHOLD" ]; then
    log "connectivity validation failed ($FAIL_COUNT/$CAMPUS_FAIL_THRESHOLD): $PROBE_DETAILS"
    save_state
    exit 0
fi

now="$(date +%s)"
delay="$(retry_delay)"
elapsed=$(( now - ${LAST_LOGIN:-0} ))
if [ "$elapsed" -lt "$delay" ]; then
    save_state
    exit 0
fi

LAST_LOGIN="$now"
save_state
log "connectivity validation failed ($FAIL_COUNT/$CAMPUS_FAIL_THRESHOLD); trying campus login: $PROBE_DETAILS"

login_once
sleep "$CAMPUS_AFTER_LOGIN_DELAY"

if probe_connectivity; then
    FAIL_COUNT=0
    LOGIN_FAILURES=0
    LAST_STATUS="ok"
    LAST_CODE="$PROBE_PRIMARY_CODE"
    log "campus login restored connectivity; portal HTTP $LOGIN_CODE; $LOGIN_SUMMARY"
else
    LOGIN_FAILURES=$(( ${LOGIN_FAILURES:-0} + 1 ))
    LAST_STATUS="fail"
    LAST_CODE="$PROBE_PRIMARY_CODE"
    delay="$(retry_delay)"
    log "campus login did not restore connectivity; portal HTTP $LOGIN_CODE; $LOGIN_SUMMARY; retry no sooner than ${delay}s; $PROBE_DETAILS"
fi

save_state
